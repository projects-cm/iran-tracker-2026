{
  "version": 2,
  "framework": "services",
  "experimentalServices": {
    "api": {
      "entrypoint": "backend/api/index.go",
      "routePrefix": "/api/v1"
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/index.html"
    }
  ]
}