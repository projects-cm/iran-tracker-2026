{
  "version": 2,
  "framework": "services",
  "experimentalServices": {
    "api": {
      "entrypoint": "backend/api/index.go",
      "routePrefix": "/api"
    },
    "client": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}